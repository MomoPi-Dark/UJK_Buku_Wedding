
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum VisitPurpose {
  DOA_RESTU
  UCAPAN_BAHAGIA
  CERITA_KENANGAN
  NASIHAT_PERNIKAHAN
  DOA_KELUARGA
  HARAPAN_MASA_DEPAN
  SALAM_KEHADIRAN
  UCAPAN_LAINNYA
}

enum GuestReactionType {
  heart
  bouquet
  sparkle
}

model GuestVisit {
  id                Int          @id @default(autoincrement())
  name              String       @db.VarChar(120)
  relation String       @db.VarChar(160)
  address           String       @db.VarChar(300)
  purpose           VisitPurpose
  otherPurposeNote  String?      @db.VarChar(255)
  photoFileId       String       @db.VarChar(191)
  photoFileName     String       @db.VarChar(191)
  photoFolderPath   String       @db.VarChar(191)
  photoMimeType     String       @db.VarChar(100)
  photoSizeBytes    Int
  photoUploadedAt   DateTime
  visitAt           DateTime     @default(now())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  reactions         GuestVisitReaction[]

  @@index([visitAt])
  @@index([purpose])
  @@index([createdAt])
  @@map("guest_visits")
}

model GuestVisitReaction {
  id           Int               @id @default(autoincrement())
  guestVisitId Int
  reactionType GuestReactionType
  reactorId    String            @db.VarChar(191)
  createdAt    DateTime          @default(now())
  guestVisit   GuestVisit        @relation(fields: [guestVisitId], references: [id], onDelete: Cascade)

  @@unique([guestVisitId, reactionType, reactorId])
  @@index([guestVisitId])
  @@index([reactionType])
  @@index([reactorId])
  @@map("guest_visit_reactions")
}

model User {
  id              String    @id
  name            String    @db.Text
  email           String
  passwordHash    String    @default("") @db.VarChar(191)
  emailVerified   Boolean   @default(false)
  image           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  username        String?
  displayUsername String?   @db.Text
  sessions        Session[]
  accounts        Account[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?  @db.Text
  userAgent String?  @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId(length: 191)])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @db.Text
  providerId            String    @db.Text
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId(length: 191)])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String   @db.Text
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier(length: 191)])
  @@map("verification")
}


model ManagementUndangan {
  id String @id
  fileId String @db.VarChar(191)
  fileName String @db.VarChar(191)
  folderPath String @db.VarChar(191)
  mimeType String @db.VarChar(100)
  sizeBytes Int
  uploadedAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("management_undangan")
}